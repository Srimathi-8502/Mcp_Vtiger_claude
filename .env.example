# =============================================================================
# Uniware Vtiger MCP Server — Phase 1 (read-only)
# Copy to .env and fill values. Never commit .env to git.
# =============================================================================

# --- Runtime ---
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
FASTMCP_STATELESS_HTTP=true

# --- MCP authentication (Claude → this server) ---
# Recommended for Microsoft 365 (@uniware.net): Microsoft Entra ID OAuth.
# Claude custom connector URL: https://<your-host>/mcp
MCP_PUBLIC_BASE_URL=https://mcp-vtiger-claude.onrender.com
OAUTH_ALLOWED_DOMAIN=uniware.net

# Microsoft Entra ID (give these values to IT — see docs/CLAUDE_SETUP.md)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REQUIRED_SCOPES=mcp-access

# Admin AMs who can view all CRM data (comma-separated emails).
VTIGER_ADMIN_EMAILS=nirmal@uniware.net

# Optional Google OAuth (only if Uniware uses Google Workspace sign-in)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_ALLOWED_DOMAIN=

# Optional legacy shared API key. Leave empty when using OAuth with Claude.
MCP_API_KEY=

# Local testing only: pretend to be this AM without OAuth.
# MCP_DEV_USER_EMAIL=dhana@uniware.net

# Optional Bearer token (FastMCP native auth).
MCP_AUTH_TOKEN=

# --- Vtiger CRM (from Dhana via Natasha) ---
VTIGER_BASE_URL=https://usp.od2.vtiger.com
VTIGER_USERNAME=api.user@uniware.com
VTIGER_ACCESS_KEY=
VTIGER_REQUEST_TIMEOUT_SECONDS=30
VTIGER_QUERY_PAGE_SIZE=100

# --- Vtiger modules ---
VTIGER_LEADS_MODULE=Leads
VTIGER_DEALS_MODULE=Potentials
VTIGER_ACCOUNTS_MODULE=Accounts
VTIGER_FIELD_ACCOUNT_NAME=accountname

# --- Field mapping (confirm exact API names with Natasha Jun 10–11) ---
# Standard fields below; follow-up / last-contacted are often custom (cf_XXXX).
VTIGER_FIELD_LEAD_OWNER=assigned_user_id
VTIGER_FIELD_LEAD_ORG=company
VTIGER_FIELD_LEAD_STATUS=leadstatus
# Leads module has no "Next Followup date" field in Vtiger (confirmed via describe).
# Leave FOLLOWUP_DATE empty until CRM adds one. DESCRIPTION uses standard field.
VTIGER_FIELD_LEAD_FOLLOWUP_DATE=
VTIGER_FIELD_LEAD_FOLLOWUP_DESC=description

VTIGER_FIELD_DEAL_OWNER=assigned_user_id
VTIGER_FIELD_DEAL_NAME=potentialname
VTIGER_FIELD_DEAL_ORG=related_to
VTIGER_FIELD_DEAL_STAGE=sales_stage
VTIGER_FIELD_DEAL_AMOUNT=amount
VTIGER_FIELD_DEAL_LAST_CONTACTED=last_contacted_on
VTIGER_FIELD_DEAL_FOLLOWUP_DATE=cf_potentials_nextfollowupdate
VTIGER_FIELD_DEAL_FOLLOWUP_DESC=nextstep

# Comma-separated open deal stages. Leave empty to return all deals for owner.
# Example: Prospecting,Qualification,Needs Analysis,Proposal/Price Quote,Negotiation/Review
VTIGER_OPEN_DEAL_STAGES=
